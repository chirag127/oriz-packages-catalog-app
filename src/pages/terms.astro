---
import Layout from "../components/Layout.astro";
---
<Layout title="Terms" hideSidebar={true}>
  <section class="hero">
    <div class="eyebrow">Legal</div>
    <h1>Terms</h1>
    <p class="lede">The packages are MIT. This catalog is MIT. Use at your own risk.</p>
  </section>
  <div class="surface prose">
    <h2>MIT, all the way down</h2>
    <p>Every package listed on this site, and the catalog itself, is licensed under the MIT license. You're free to use, modify, and redistribute, with or without modification.</p>
    <h2>No warranty</h2>
    <p>Provided "as is", without warranty of any kind, express or implied. See each package's <code>LICENSE</code> file for the full text.</p>
    <h2>Contact</h2>
    <p>Open an issue on <a href="https://github.com/chirag127" rel="noopener">GitHub</a>.</p>
  </div>
</Layout>
