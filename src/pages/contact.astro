---
import Layout from "../components/Layout.astro";
---
<Layout title="Contact" hideSidebar={true}>
  <section class="hero">
    <div class="eyebrow">Get in touch</div>
    <h1>Contact</h1>
    <p class="lede">Bug, feature, broken link, or just want to say hi.</p>
  </section>
  <div class="surface prose">
    <h2>GitHub</h2>
    <p>Open an issue on the relevant package, or on the catalog repo itself: <a href="https://github.com/chirag127/oriz-packages-catalog-app" rel="noopener">chirag127/oriz-packages-catalog-app</a>.</p>
    <h2>npm</h2>
    <p>All packages live under <a href="https://www.npmjs.com/~chirag127" rel="noopener">npmjs.com/~chirag127</a>.</p>
  </div>
</Layout>
