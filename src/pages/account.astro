---
import Layout from "../components/Layout.astro";
---
<Layout title="Account" current="me" hideSidebar={true}>
  <section class="hero">
    <div class="eyebrow">Account</div>
    <h1>Your account</h1>
    <p class="lede">Accounts ship in v0.5. The catalog is fully public for now.</p>
  </section>
  <div class="surface prose">
    <p>Planned: starred packages, release notifications, contribution streaks. None of which require you to give us anything beyond an email.</p>
    <p><a href="/" class="button">Browse packages</a></p>
  </div>
</Layout>
